# Auto detect text files and normalize to LF in repo, but keep CRLF in working directory
* text=auto

# All text files: LF in repo, auto (CRLF on Windows) in working directory
*.cs text
*.csproj text
*.sln text
*.slnx text
*.md text
*.json text
*.xml text
*.yml text
*.yaml text

# Unix scripts must always use LF
*.sh text eol=lf

# Windows-specific files use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.dll binary
*.exe binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
